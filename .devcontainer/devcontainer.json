{
  "name": "NL Proxy VPN - Professional Codespace",
  "image": "mcr.microsoft.com/devcontainers/universal:2-linux",
  
  "features": {
    "ghcr.io/devcontainers/features/docker-in-docker:2": {},
    "ghcr.io/devcontainers/features/git:1": {},
    "ghcr.io/devcontainers/features/github-cli:1": {}
  },
  
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance",
        "charliermarsh.ruff",
        "ms-vscode.cpptools",
        "ms-vscode-remote.remote-containers",
        "GitHub.copilot",
        "ms-vscode.makefile-tools",
        "eamodio.gitlens",
        "ms-azuretools.vscode-docker",
        "ms-vscode-remote.vscode-remote-extensionpack",
        "DavidAnson.vscode-markdownlint",
        "yzhang.markdown-all-in-one",
        "streetsidesoftware.code-spell-checker",
        "esbenp.prettier-vscode",
        "tamasfe.even-better-toml"
      ],
      
      "settings": {
        "python.defaultInterpreterPath": "/usr/local/bin/python3",
        "python.linting.enabled": true,
        "python.linting.pylintEnabled": true,
        "python.linting.pylintPath": "/usr/local/bin/pylint",
        "python.formatting.provider": "black",
        "python.formatting.blackPath": "/usr/local/bin/black",
        "[python]": {
          "editor.formatOnSave": true,
          "editor.defaultFormatter": "ms-python.python",
          "editor.codeActionsOnSave": {
            "source.organizeImports": true
          }
        },
        "editor.formatOnSave": true,
        "editor.defaultFormatter": "esbenp.prettier-vscode",
        "editor.rulers": [80, 120],
        "editor.wordWrap": "on",
        "files.watcherExclude": {
          "**/.git/objects/**": true,
          "**/.git/subtree-cache/**": true,
          "**/node_modules/*/**": true
        },
        "python.testing.pytestEnabled": true,
        "python.testing.unittestEnabled": false,
        "editor.fontSize": 14,
        "editor.tabSize": 4,
        "editor.insertSpaces": true,
        "editor.trimAutoWhitespace": true,
        "files.trimTrailingWhitespace": true,
        "files.insertFinalNewline": true
      }
    }
  },
  
  "remoteUser": "codespace",
  
  "remoteEnv": {
    "PATH": "${containerEnv:PATH}:/home/codespace/.local/bin",
    "PYTHONUNBUFFERED": "1",
    "LANG": "C.UTF-8",
    "LC_ALL": "C.UTF-8"
  },
  
  "postCreateCommand": "bash .devcontainer/post-create.sh",
  
  "postStartCommand": "bash .devcontainer/post-start.sh",
  
  "forwardPorts": [
    8080,
    1080,
    1194,
    3000,
    8000,
    9090,
    9091
  ],
  
  "portsAttributes": {
    "8080": {
      "label": "HTTP Proxy",
      "onAutoForward": "notify"
    },
    "1080": {
      "label": "SOCKS5 Proxy",
      "onAutoForward": "notify"
    },
    "1194": {
      "label": "VPN",
      "onAutoForward": "notify"
    },
    "3000": {
      "label": "API Server",
      "onAutoForward": "notify"
    },
    "8000": {
      "label": "Dev Server",
      "onAutoForward": "notify"
    },
    "9090": {
      "label": "Prometheus",
      "onAutoForward": "notify"
    },
    "9091": {
      "label": "Dashboard",
      "onAutoForward": "notify"
    }
  },
  
  "mounts": [
    "source=${localEnv:HOME}${localEnv:USERPROFILE}/.ssh,target=/home/codespace/.ssh,type=bind,consistency=cached"
  ],
  
  "containerEnv": {
    "DEBIAN_FRONTEND": "noninteractive"
  },
  
  "updateContentCommand": "bash .devcontainer/post-start.sh",
  
  "capAdd": [
    "SYS_PTRACE"
  ],
  
  "securityOpt": [
    "seccomp=unconfined"
  ]
}
